generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  NBP
  PAYSYS
  VENDOR
  AUDITOR
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ScopingRecordStatus {
  DRAFT
  FINAL
}

enum UserRole {
  SYSTEM_ADMIN
  NBP_SECURITY_ADMIN
  NBP_VIEWER
  PAYSYS_SECURITY_ADMIN
  PAYSYS_DEVELOPER
  VENDOR_ADMIN
  AUDITOR
}

enum AssessmentType {
  WHITEBOX
  BLACK_GREY
}

enum EngagementStatus {
  PLANNED
  PAYSYS_APPRISE_INITIATED
  APPRISE_ASSESSMENT
  DRAFT_REPORT_UPLOADED
  PAYSYS_TRIAGE
  DEVELOPER_FIX
  FIXED_PENDING_REVALIDATION
  APPRISE_REVALIDATION
  FINAL_REPORT_UPLOADED
  PAYSYS_IS_REVIEW_AND_COMMENT
  NBP_IS_REVIEW_CLOSING_MEETING
  CLOSED
  GO_LIVE
  CANCELLED
}

enum ReportType {
  DRAFT_REPORT
  REVALIDATION_REPORT
  FINAL_REPORT
  RISK_ACCEPTANCE_DOCUMENT
  EVIDENCE_DOCUMENT
  ADDENDUM
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum FindingStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  FIX_IMPLEMENTED
  FIXED_PENDING_REVALIDATION
  REVALIDATION_PASSED
  REVALIDATION_FAILED
  RISK_ACCEPTANCE_REQUESTED
  RISK_ACCEPTED
  CLOSED
}

enum EvidenceType {
  SCREENSHOT
  JIRA_REFERENCE
  GIT_COMMIT
  CONFIG_CHANGE
  DEPLOYMENT_EVIDENCE
  TEST_RESULT
  DOCUMENT
  OTHER
}

enum RevalidationResult {
  PASSED
  FAILED
}

enum RiskAcceptanceStatus {
  REQUESTED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

model Organization {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @unique @db.VarChar(150)
  organizationType OrganizationType
  status           RecordStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  users            User[]
  vendorEngagements VaptEngagement[] @relation("VendorEngagements")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  keycloakUserId String        @unique @db.VarChar(150)
  fullName       String        @db.VarChar(150)
  email          String        @unique @db.VarChar(150)
  role           UserRole
  status         RecordStatus  @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdApplications Application[] @relation("ApplicationCreator")
  createdEngagements  VaptEngagement[] @relation("EngagementCreator")
  createdReports      Report[] @relation("ReportCreator")
  uploadedReportVersions ReportVersion[] @relation("ReportVersionUploader")
  createdFindings     Finding[] @relation("FindingCreator")
  closedFindings      Finding[] @relation("FindingCloser")
  assignedFindings    Finding[] @relation("FindingAssignee")
  changedFindingStatuses FindingStatusHistory[] @relation("FindingStatusChanger")
  uploadedFindingEvidence FindingEvidence[] @relation("FindingEvidenceUploader")
  performedRevalidations Revalidation[] @relation("RevalidationPerformer")
  requestedRiskAcceptances RiskAcceptance[] @relation("RiskAcceptanceRequester")
  reviewedRiskAcceptances RiskAcceptance[] @relation("RiskAcceptanceReviewer")
  auditLogs           AuditLog[]
}

model Application {
  id                 String           @id @default(uuid()) @db.Uuid
  name               String           @db.VarChar(200)
  description        String?
  businessOwnerName  String?          @db.VarChar(150)
  technicalOwnerName String?          @db.VarChar(150)
  environment        String           @db.VarChar(50)
  url                String?
  criticality        String           @db.VarChar(30)
  technologyStack    String?
  internetFacing     Boolean          @default(false)
  status             RecordStatus     @default(ACTIVE)
  createdById        String           @db.Uuid
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          User             @relation("ApplicationCreator", fields: [createdById], references: [id])
  engagements        VaptEngagement[]

  @@index([status])
  @@index([criticality])
}

model VaptEngagement {
  id                   String           @id @default(uuid()) @db.Uuid
  applicationId         String           @db.Uuid
  title                 String           @db.VarChar(250)
  assessmentType        AssessmentType
  plannedStartDate      DateTime?
  plannedEndDate        DateTime?
  plannedMonth          String?          @db.VarChar(20)
  plannedYear           Int
  actualStartDate       DateTime?
  actualEndDate         DateTime?
  vendorOrganizationId  String?          @db.Uuid
  status                EngagementStatus @default(PLANNED)
  closureNotes          String?
  closedById            String?          @db.Uuid
  closedAt              DateTime?
  createdById           String           @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  application           Application      @relation(fields: [applicationId], references: [id])
  vendorOrganization    Organization?    @relation("VendorEngagements", fields: [vendorOrganizationId], references: [id])
  createdBy             User             @relation("EngagementCreator", fields: [createdById], references: [id])
  scopingRecords        ScopingRecord[]
  reports               Report[]
  findings              Finding[]
  revalidations          Revalidation[]
  riskAcceptances        RiskAcceptance[]

  @@index([applicationId])
  @@index([plannedYear, plannedMonth])
  @@index([status])
  @@index([vendorOrganizationId])
}

model ScopingRecord {
  id                 String         @id @default(uuid()) @db.Uuid
  engagementId       String         @db.Uuid
  meetingDate        DateTime
  meetingTime        String?        @db.VarChar(20)
  participants       String
  minutes            String?
  scopeIncluded      String
  scopeExcluded      String?
  testingWindowStart DateTime?
  testingWindowEnd   DateTime?
  testAccountsSummary String?
  architectureSummary String?
  recordStatus       ScopingRecordStatus @default(DRAFT)
  finalizedAt        DateTime?
  finalizedById      String?        @db.Uuid
  createdById        String         @db.Uuid
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  engagement         VaptEngagement @relation(fields: [engagementId], references: [id])

  @@index([engagementId])
}

model Report {
  id             String          @id @default(uuid()) @db.Uuid
  engagementId   String          @db.Uuid
  reportType     ReportType
  title          String          @db.VarChar(250)
  description    String?
  currentVersion Int             @default(1)
  status         RecordStatus    @default(ACTIVE)
  immutable      Boolean         @default(false)
  createdById    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  engagement     VaptEngagement  @relation(fields: [engagementId], references: [id])
  createdBy      User            @relation("ReportCreator", fields: [createdById], references: [id])
  versions       ReportVersion[]
}

model ReportVersion {
  id                  String      @id @default(uuid()) @db.Uuid
  reportId            String      @db.Uuid
  versionNumber       Int
  fileName            String      @db.VarChar(255)
  fileMimeType        String      @db.VarChar(100)
  fileSizeBytes       BigInt
  objectStorageKey    String
  sha256Hash          String      @unique @db.VarChar(64)
  isPasswordProtected Boolean     @default(false)
  uploadedById        String      @db.Uuid
  uploadedAt          DateTime    @default(now())
  uploadNotes         String?
  report              Report      @relation(fields: [reportId], references: [id])
  uploadedBy          User        @relation("ReportVersionUploader", fields: [uploadedById], references: [id])
  sourceFindings      Finding[]   @relation("FindingSourceReportVersion")
  revalidations       Revalidation[]

  @@unique([reportId, versionNumber])
}

model Finding {
  id                    String          @id @default(uuid()) @db.Uuid
  engagementId          String          @db.Uuid
  sourceReportVersionId String?         @db.Uuid
  findingReference      String          @db.VarChar(100)
  title                 String          @db.VarChar(300)
  description           String
  impact                String?
  recommendation        String?
  severity              FindingSeverity
  cvssScore             Decimal?        @db.Decimal(3, 1)
  cwe                   String?         @db.VarChar(50)
  owaspCategory         String?         @db.VarChar(100)
  status                FindingStatus   @default(OPEN)
  assignedToUserId      String?         @db.Uuid
  dueDate               DateTime?
  fixedAt               DateTime?
  closedAt              DateTime?
  closedById            String?         @db.Uuid
  createdById           String          @db.Uuid
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  engagement            VaptEngagement  @relation(fields: [engagementId], references: [id])
  sourceReportVersion   ReportVersion?   @relation("FindingSourceReportVersion", fields: [sourceReportVersionId], references: [id])
  assignedTo            User?           @relation("FindingAssignee", fields: [assignedToUserId], references: [id])
  createdBy             User            @relation("FindingCreator", fields: [createdById], references: [id])
  closedBy              User?           @relation("FindingCloser", fields: [closedById], references: [id])
  statusHistory         FindingStatusHistory[]
  evidence              FindingEvidence[]
  revalidations         Revalidation[]
  riskAcceptances       RiskAcceptance[]

  @@index([engagementId])
  @@index([status])
  @@index([severity])
  @@index([assignedToUserId])
  @@index([dueDate])
}

model FindingStatusHistory {
  id          String        @id @default(uuid()) @db.Uuid
  findingId   String        @db.Uuid
  oldStatus   FindingStatus?
  newStatus   FindingStatus
  changedById String        @db.Uuid
  comments    String?
  changedAt   DateTime      @default(now())
  finding     Finding       @relation(fields: [findingId], references: [id])
  changedBy   User          @relation("FindingStatusChanger", fields: [changedById], references: [id])

  @@index([findingId])
  @@index([newStatus])
}

model FindingEvidence {
  id                 String       @id @default(uuid()) @db.Uuid
  findingId          String       @db.Uuid
  evidenceType       EvidenceType
  title              String       @db.VarChar(250)
  notes              String?
  fileObjectKey      String?
  fileName           String?      @db.VarChar(255)
  fileMimeType       String?      @db.VarChar(100)
  fileSizeBytes      BigInt?
  jiraReference      String?      @db.VarChar(150)
  gitCommitReference String?      @db.VarChar(150)
  uploadedById       String       @db.Uuid
  uploadedAt         DateTime     @default(now())
  finding            Finding      @relation(fields: [findingId], references: [id])
  uploadedBy         User         @relation("FindingEvidenceUploader", fields: [uploadedById], references: [id])

  @@index([findingId])
  @@index([uploadedById])
}

model Revalidation {
  id              String             @id @default(uuid()) @db.Uuid
  findingId       String             @db.Uuid
  engagementId    String             @db.Uuid
  revalidationDate DateTime
  result          RevalidationResult
  remarks         String?
  performedById   String             @db.Uuid
  reportVersionId String?            @db.Uuid
  createdAt       DateTime           @default(now())
  finding         Finding            @relation(fields: [findingId], references: [id])
  engagement      VaptEngagement     @relation(fields: [engagementId], references: [id])
  performedBy     User               @relation("RevalidationPerformer", fields: [performedById], references: [id])
  reportVersion   ReportVersion?     @relation(fields: [reportVersionId], references: [id])

  @@index([findingId])
  @@index([engagementId])
  @@index([result])
}

model RiskAcceptance {
  id                    String               @id @default(uuid()) @db.Uuid
  findingId             String               @db.Uuid
  engagementId          String               @db.Uuid
  riskDescription       String
  businessJustification String
  mitigatingControls    String?
  expiryDate            DateTime
  status                RiskAcceptanceStatus @default(REQUESTED)
  requestNotes          String?
  reviewNotes           String?
  requestedById         String               @db.Uuid
  reviewedById          String?              @db.Uuid
  requestedAt           DateTime             @default(now())
  reviewedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  finding               Finding              @relation(fields: [findingId], references: [id])
  engagement             VaptEngagement       @relation(fields: [engagementId], references: [id])
  requestedBy           User                 @relation("RiskAcceptanceRequester", fields: [requestedById], references: [id])
  reviewedBy            User?                @relation("RiskAcceptanceReviewer", fields: [reviewedById], references: [id])

  @@index([findingId])
  @@index([engagementId])
  @@index([status])
  @@index([expiryDate])
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @db.Uuid
  organizationId String?  @db.Uuid
  action         String   @db.VarChar(120)
  entityType     String   @db.VarChar(80)
  entityId       String?  @db.Uuid
  oldValue       Json?
  newValue       Json?
  remarks        String?
  ipAddress      String?  @db.VarChar(80)
  userAgent      String?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])
}
