SECURETRACKER_DEPLOYMENT_MODE=production

PUBLIC_FRONTEND_URL=https://securetracker.example.local
PUBLIC_BACKEND_URL=https://securetracker-api.example.local
CORS_ORIGIN=https://securetracker.example.local
BACKEND_PORT=3000

POSTGRES_USER=securetracker
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=securetracker
DATABASE_URL=postgresql://securetracker:change-me-postgres-password@postgres:5432/securetracker?schema=public

KEYCLOAK_ISSUER_URL=https://idp.example.local/realms/securetracker
KEYCLOAK_JWKS_URL=https://idp.example.local/realms/securetracker/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=securetracker-web
VITE_KEYCLOAK_URL=https://idp.example.local
VITE_KEYCLOAK_REALM=securetracker
VITE_KEYCLOAK_CLIENT_ID=securetracker-web
VITE_API_BASE_URL=https://securetracker-api.example.local

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=vapt-tracker

SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=SecureTracker <securetracker@example.local>

NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_SCHEDULER_ENABLED=false
NOTIFICATION_REMINDER_DAYS=7
RISK_ACCEPTANCE_EXPIRY_REMINDER_DAYS=14
REGRESSION_DATA_PREFIX=REGRESSION_
