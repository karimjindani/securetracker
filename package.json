{
  "name": "securetracker",
  "version": "0.5.0",
  "private": true,
  "description": "VAPT Tracker Portal monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test:e2e": "playwright test",
    "test:regression": "playwright test --project=regression",
    "test:regression:headed": "playwright test --project=regression --headed",
    "test:data:cleanup": "tsx scripts/test-data-cleanup.ts",
    "reset:seeded": "tsx scripts/reset-seeded.ts",
    "ops": "node tools/ops-console/server.mjs",
    "ops:dev": "node tools/ops-console/server.mjs",
    "typecheck": "npm run typecheck -w @securetracker/shared && npm run build -w @securetracker/shared && npm run typecheck -w @securetracker/backend && npm run typecheck -w @securetracker/frontend",
    "lint": "node scripts/lint.mjs",
    "test": "npm run test -w @securetracker/shared && npm run test -w @securetracker/backend && npm run test -w @securetracker/frontend",
    "build": "npm run build -w @securetracker/shared && npm run build -w @securetracker/backend && npm run build -w @securetracker/frontend",
    "dev:backend": "npm run dev -w @securetracker/backend",
    "dev:frontend": "npm run dev -w @securetracker/frontend"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.19.3",
    "typescript": "^5.8.3",
    "@playwright/test": "^1.56.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "jose": "^6.2.3",
    "keycloak-js": "^26.2.4",
    "react-router-dom": "^7.18.1"
  }
}
